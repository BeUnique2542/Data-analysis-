UPDATE employees
SET salary = salary * 1.05         -- 5% increment
WHERE department = 'HR';           -- Sirf HR ke liye

-- ✅ DELETE: record hataana (caution)
DELETE FROM employees
WHERE name = 'AMIT' AND department = 'Data Science';  -- Specific record delete

