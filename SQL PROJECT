-- ✅ DDL: Database banana (naya DB create)
CREATE DATABASE ORG_DB;        -- Naya database ORG_DB banaya
USE ORG_DB;                    -- Ab hum isi database mein kaam karenge

-- ✅ DDL: Tables design (schema) — real-world HR + Payroll + Accounts + Customers
-- Employees: core master table
CREATE TABLE employees (
  id INT PRIMARY KEY AUTO_INCREMENT,       -- Unique employee ID, auto increment (roll-number jaisa)
  name VARCHAR(50) NOT NULL,               -- Employee ka naam (empty allow nahi)
  department VARCHAR(30) NOT NULL,         -- Department (e.g., Data Science, HR)
  salary DECIMAL(10,2) NOT NULL,           -- Salary with 2 decimal places (₹ format)
  hired_at DATE DEFAULT (CURRENT_DATE)     -- Hiring date (default: aaj ki date)
);

-- Payroll: transactional payments linked to employees
CREATE TABLE payroll (
  id INT PRIMARY KEY AUTO_INCREMENT,       -- Unique payment record
  emp_id INT NOT NULL,                     -- Kis employee ko payment hua (FK)
  amount DECIMAL(10,2) NOT NULL,           -- Payment amount
  payment_date DATE NOT NULL,              -- Payment date
  CONSTRAINT fk_payroll_emp FOREIGN KEY (emp_id) REFERENCES employees(id)   -- Relationship set
);

-- Accounts: banking style table for transactions example
CREATE TABLE accounts (
  id INT PRIMARY KEY AUTO_INCREMENT,       -- Account ID
  holder VARCHAR(50) NOT NULL,             -- Account holder name
  balance DECIMAL(12,2) NOT NULL DEFAULT 0 -- Current balance
);

-- Customers: JSON use-case (modern apps store semi-structured details)
CREATE TABLE customers (
  id INT PRIMARY KEY AUTO_INCREMENT,       -- Customer ID
  name VARCHAR(50) NOT NULL,               -- Customer name
  details JSON                             -- JSON blob (address, preferences, etc.)
);

-- Indexes for common queries (fast lookups on filters)
CREATE INDEX idx_employees_department ON employees(department);  -- Department filter fast
CREATE INDEX idx_payroll_emp_date ON payroll(emp_id, payment_date); -- Emp + date queries fast



