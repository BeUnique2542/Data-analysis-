FROM employees e
LEFT JOIN payroll p ON e.id = p.emp_id;    -- Unpaid employees bhi dikhenge (NULL amounts)

-- ✅ Aggregation: department-wise average salary (reporting)
SELECT department, AVG(salary) AS avg_salary
FROM employees
GROUP BY department;                       -- Summary per department

-- ✅ Add business rule: Min salary check via generated column or application logic
-- MySQL CHECK is limited; better to enforce in app or via trigger.
-- Example: Trigger to enforce MIN salary = 30000
DELIMITER //
CREATE TRIGGER trg_min_salary BEFORE INSERT ON employees
FOR EACH ROW
BEGIN
  IF NEW.salary < 30000 THEN
    SET NEW.salary = 30000;        -- Floor enforce: rookie mistakes avoid
  END IF;
END //
DELIMITER ;

-- ✅ Stored Procedure: reusable query (find high earners)
DELIMITER //
CREATE PROCEDURE GetHighSalaryEmployees(IN threshold DECIMAL(10,2))
BEGIN
  SELECT * FROM employees WHERE salary > threshold;   -- Param-driven filter
END //
DELIMITER ;

CALL GetHighSalaryEmployees(50000);   -- Use-case: dashboard filter

-- ✅ Scalar Function: normalize department text
DELIMITER //
CREATE FUNCTION normalize_dept(dept VARCHAR(30))
RETURNS VARCHAR(30)
DETERMINISTIC
BEGIN
  RETURN UPPER(TRIM(dept));   -- Clean + uppercase
END //
DELIMITER ;

-- Use function in query
SELECT id, name, normalize_dept(department) AS dept_clean
FROM employees;


-- ✅ Accounts seed data
INSERT INTO accounts (holder, balance) VALUES
('Alice', 10000),
('Bob', 2000);

-- ✅ Transaction: atomic money transfer (either fully succeeds or rolls back)
START TRANSACTION;                                -- Begin
UPDATE accounts SET balance = balance - 1000 WHERE holder = 'Alice';  -- Debit Alice
UPDATE accounts SET balance = balance + 1000 WHERE holder = 'Bob';    -- Credit Bob

-- Validate: prevent negative balance (simple guard)
-- If any issue, ROLLBACK; else COMMIT;
COMMIT;                                           -- Save changes
-- ROLLBACK;                                     -- Use if any step fails


-- ✅ Before-insert trigger: department ko uppercase enforce
DELIMITER //
CREATE TRIGGER before_insert_employee
BEFORE INSERT ON employees
FOR EACH ROW
BEGIN
  SET NEW.department = UPPER(NEW.department);  -- Consistent data format
END //
DELIMITER ;


-- ✅ Ranking: salary-based rank (analytics dashboards)
SELECT name, department, salary,
       RANK() OVER (ORDER BY salary DESC) AS salary_rank     -- Ties share rank
FROM employees;

-- ✅ Running totals: department-wise cumulative payroll
SELECT e.department, p.payment_date, p.amount,
       SUM(p.amount) OVER (PARTITION BY e.department ORDER BY p.payment_date) AS dept_running_total
FROM payroll p
JOIN employees e ON e.id = p.emp_id;


-- ✅ Subquery: department with above-average salaries
SELECT name, department, salarystudent
FROM employees
WHERE salary > (
  SELECT AVG(salary) FROM employees WHERE department = 'Data Science'  -- Dept avg
);

-- ✅ CTE: readable stepwise logic (MySQL 8+)
WITH dept_stats AS (
  SELECT department, AVG(salary) AS avg_sal, COUNT(*) AS cnt
  FROM employees
  GROUP BY department
)
SELECT e.name, e.department, e.salary, d.avg_sal, d.cnt
FROM employees e
JOIN dept_stats d ON e.department = d.department;

-- ✅ View: saved query for reporting
CREATE OR REPLACE VIEW v_dept_summary AS
SELECT department, COUNT(*) AS emp_count, AVG(salary) AS avg_salary
FROM employees
GROUP BY department;

-- Use the view
SELECT * FROM v_dept_summary;

SELECT name,
       CASE
         WHEN salary >= 70000 THEN 'High'
         WHEN salary >= 50000 THEN 'Mid'
         ELSE 'Low'
       END AS band
FROM employees;


